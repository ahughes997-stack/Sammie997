# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenRouter API Key (from openrouter.ai/keys)
OPENROUTER_API_KEY=

# Groq API Key for voice transcription (free at console.groq.com)
# Optional — voice messages won't work without this
GROQ_API_KEY=

# Comma-separated Telegram user IDs allowed to use the bot
# Find yours: message @userinfobot on Telegram
ALLOWED_USER_IDS=

# Serper.dev API Key for Google Search (free at serper.dev)
# Optional — web search won't work without this
SERPER_API_KEY=

# Gmail / Google Cloud Platform credentials
# Required for Gmail integration
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_REFRESH_TOKEN=

# Google Cloud Pub/Sub Topic Name for real-time notifications
# Format: projects/{project-id}/topics/{topic-name}
PUBSUB_TOPIC_NAME=
